# ──────────────────────────────────────────────────────────────────
#  作者文学 IP — 不属于代码仓库
#  这些是《我蕾穆丽娜不爱你》的原文 / 大纲 / 设定集,
#  保留在本地磁盘但不入 git;公开开源前用 git filter-repo 清掉 history。
# ──────────────────────────────────────────────────────────────────
/正文/
/大纲/
/设定集/
# 任何 *.md 在仓库根级直接放小说原文的目录变种
/novel/
/chapters/
/manuscript/

# ──────────────────────────────────────────────────────────────────
#  Python / 运行时缓存
# ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ──────────────────────────────────────────────────────────────────
#  macOS / 编辑器临时
# ──────────────────────────────────────────────────────────────────
.DS_Store

# ──────────────────────────────────────────────────────────────────
#  secrets — 任何泄露会导致 RCE / 凭证泄露 / 用户数据被解的
# ──────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
# Google / GCP service account JSON（任何匹配的都禁）
rpg/vertex_sa.json
**/vertex_sa*.json
**/service_account*.json
**/*_sa.json
**/google_credentials*.json
**/gcp_credentials*.json
# 通用凭证文件
**/credentials.json
**/secrets.json
**/*.pem
**/*.key
!rpg/tests/**/*.pem
# AES-GCM 主密钥，泄露 = 所有用户存的 API key 可解
rpg/platform_data/master.key
# 用户上传文件 / 分片暂存 / 已导入剧本（私人正文）
rpg/platform_data/library/
rpg/platform_data/upload_chunks/
rpg/platform_data/scripts/

# ──────────────────────────────────────────────────────────────────
#  本地虚拟环境
# ──────────────────────────────────────────────────────────────────
rpg_env/

# ──────────────────────────────────────────────────────────────────
#  小说工作区数据库（体积大且可重建，不入库）
# ──────────────────────────────────────────────────────────────────
.webnovel/vectors.db
.webnovel/vectors.db.*.bak
.webnovel/backups/
.webnovel/perf_*.jsonl
.webnovel/chapter_facts.db
.webnovel/index.db
.webnovel/observability/*.jsonl

# ──────────────────────────────────────────────────────────────────
#  Rust 运行时产物（platform_data 分片暂存 + state 文件）
# ──────────────────────────────────────────────────────────────────
rust/platform_data/
rust/crates/rpg-platform/platform_data/
# cargo 编译产物 — 本地达到 78GB,绝对不入库
rust/target/
**/target/

# ──────────────────────────────────────────────────────────────────
#  RPG 后端运行时产物（重启可重建 / 玩家私有）
# ──────────────────────────────────────────────────────────────────
# 分支状态快照（大量 JSON）
rpg/platform_data/branch_states/
# 旧版 JSON runtime 备份（B2 后只在迁移时用）
rpg/platform_data/runtime/
# 运行时快照
rpg/platform_data/runtime_states/
# 单用户本地存档
rpg/saves/
# 老版本检索 fallback JSON
rpg/indexes/
# 老 sqlite db（B0/B1 已 fade out）
rpg/db/
# Claude Design 拖入静态资源（可重建）
rpg/claude_design_upload/

# ──────────────────────────────────────────────────────────────────
#  前端构建产物 / 用户上传图
# ──────────────────────────────────────────────────────────────────
# 用户上传图片（私人 / 体积大）
frontend/uploads/
frontend/node_modules/
frontend/dist/
frontend/.next/
# 截图素材（体积变化大）
frontend/screenshots/

# ──────────────────────────────────────────────────────────────────
#  UI 审计 / E2E 产物（每次 audit 会写大量 png/json/log，不入库）
# ──────────────────────────────────────────────────────────────────
# Playwright e2e audit 输出（截图、SSE 转录、覆盖 JSON、剧本素材）
output/
# Playwright CLI 安装的浏览器缓存
.playwright-cli/

# ──────────────────────────────────────────────────────────────────
#  编辑器 / IDE / Claude Code 会话缓存
# ──────────────────────────────────────────────────────────────────
.claude/
.vscode/
.idea/
*.swp
*.swo

# ──────────────────────────────────────────────────────────────────
#  task 87 工具化阶段后引入的本地 venv / 生成报告
# ──────────────────────────────────────────────────────────────────
rpg/.venv/
# tool 工具生成的契约漂移报告(可重新生成,不入库)
rpg/docs/api_contract_drift.md

# dev-server logs (scripts/dev.sh)
.dev-logs/

# ──────────────────────────────────────────────────────────────────
#  小说原文 / 内容资产 — 版权敏感,绝不入公开/私有仓库
# ──────────────────────────────────────────────────────────────────
# 原始 TXT (~14MB)
*.txt
# 但 Rust prompt 文件必须入库(include_str! 编译时引用)
!rust/crates/rpg-agents/src/prompts/*.txt
# 拆好的 1310 章 markdown (~14MB)
正文/
# 大纲 + 设定集
大纲/
设定集/

# requirements.txt 是代码依赖清单,不是小说原文 — 白名单
!rpg/requirements.txt

# ──────────────────────────────────────────────────────────────────
#  凭据兜底 — 任何 SQLite/dump 文件默认不入库
# ──────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.dump
# 例外:测试 fixture 数据库
!rpg/tests/**/*.db
!rpg/tests/**/*.sqlite

# ──────────────────────────────────────────────────────────────────
#  本地状态补漏
# ──────────────────────────────────────────────────────────────────
.webnovel/state.json
.webnovel/*.db

# ──────────────────────────────────────────────────────────────────
#  内部交接 / 审计文档 — 永久不入公开仓库
# ──────────────────────────────────────────────────────────────────
/README.legacy.md
/rpg/CLAUDE_CODE_HANDOFF.md
/rpg/SECURITY_AUDIT.md

# ──────────────────────────────────────────────────────────────────
#  小说 IP 词汇表 — 私有 override（开源版用 .example.json）
# ──────────────────────────────────────────────────────────────────
rpg/config/novel_glossary.json
rpg/config/*.private.json

# copyrighted novel test fixtures — never publish
.test-fixtures/
