# RPG Roleplay — environment template (bare-metal / self-hosted)
# Copy to .env and fill in:  cp .env.example .env
# Do NOT commit your real .env. Only DATABASE_URL is required to boot in local mode.

# ── Database (REQUIRED) ─────────────────────────────────────────────
# Must match the role/db you created in the Quick Start (user `rpg`, db `rpg`).
# Use a DIRECT Postgres connection (5432) — both for `migrate` and runtime
# on a single node.
# !! `migrate` must NOT go through PgBouncer (6432): the advisory lock it uses
#    does not work under transaction pooling. Point runtime at PgBouncer only
#    if you deploy one (see deploy/bare-metal/README.md).
DATABASE_URL=postgresql://rpg:rpg_dev@127.0.0.1:5432/rpg

# ── Encryption master key (recommended) ─────────────────────────────
# Encrypts stored user API keys at rest. If unset, a key file is generated
# automatically on first boot — BACK IT UP; losing it makes saved keys
# unreadable. To pin an explicit key:  openssl rand -hex 32
# RPG_MASTER_KEY=

# ── Auth mode ───────────────────────────────────────────────────────
# Unset / 0  = local single-user, auth OFF — no registration, no email needed.
# 1          = multi-user / public: enables login + registration (see below).
# RPG_REQUIRE_AUTH=0

# ── Default LLM (optional) ──────────────────────────────────────────
# Each user brings their own keys via the UI (BYOK). This is only a
# server-side fallback before anyone has configured a provider.
# ANTHROPIC_API_KEY=

# ── Embeddings for retrieval (optional, configurable in the UI) ─────
# Without an embedder, semantic retrieval is off (keyword search still works).
# EMBED_BASE_URL=
# EMBED_MODEL=text-embedding-004
# EMBED_API_KEY=

# ── Redis (optional — graceful fallback if unset) ───────────────────
# Used for rate-limiting + cache. Unset = in-process fallback (fine for a
# single node).
# REDIS_URL=redis://127.0.0.1:6379/0

# ── Multi-user / public deployment only (needed when RPG_REQUIRE_AUTH=1) ──
# Comma-separated allowed CORS origins when the frontend is served separately:
# RPG_CORS_ORIGINS=https://your-domain.example
# Registration sends an email verification code via Resend — REQUIRED for
# self-service signup. Without it, no one (including the first admin) can
# register, so configure Resend or keep auth off (local mode).
# RESEND_API_KEY=
# RESEND_FROM=Your Name <noreply@your-domain.example>
# One-time token to let the first registration become admin (server mode):
# openssl rand -hex 32   — then remove it after the first admin is created.
# RPG_SETUP_TOKEN=
