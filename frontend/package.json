{
  "name": "rpg-roleplay-frontend",
  "private": true,
  "version": "1.28.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:types": "cd ../rust && cargo test -p rpg-schemas --features ts-rs && cargo test -p rpg-state --features ts-rs && cargo test -p rpg-llm --features ts-rs && cargo test -p rpg-routes --features ts-rs"
  },
  "dependencies": {
    "@cloudscape-design/components": "^3.0.1318",
    "@cloudscape-design/global-styles": "^1.0.61",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.3",
    "i18next": "^26.3.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "web-vitals": "^5.3.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
