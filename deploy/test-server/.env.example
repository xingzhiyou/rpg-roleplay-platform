# RPG Roleplay 测试服 ECS06 — 环境变量模板
# 复制为 .env 后填入实际值。**不要 commit .env 进 git!**

# ── DATABASE_URL 注意事项 ──────────────────────────────────────
# 开发/本地:       DATABASE_URL=postgresql://rpg:rpg_dev@127.0.0.1:5432/rpg  (直连 PG)
# 测试服 Docker:   DATABASE_URL 由 docker-compose.yml 通过 pgbouncer:6432 注入
#                  migration 在 docker 内跑时后端直连 postgres:5432（compose service name）
# 裸机生产:
#   - migrate 阶段: DATABASE_URL=postgresql://rpg:PASS@127.0.0.1:5432/rpg  ← 直连 PG
#   - 运行时:       DATABASE_URL=postgresql://rpg:PASS@127.0.0.1:6432/rpg  ← PgBouncer
#   详见 deploy/bare-metal/README.md §3
# !! migration 绝对不能走 PgBouncer (6432) —— advisory lock 在 transaction 池下失效 !!

# ── DB / Redis 密码(必填,强口令)─────────────────────────────────
# openssl rand -base64 32
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# ── 加密主密钥(必填,泄露=所有 user API key 可解)────────────────
# openssl rand -hex 32
# 注意:轮换需要 re-encrypt 已有 user_api_credentials,提前规划
RPG_MASTER_KEY=

# ── 邮件(B12 注册验证码)── 复用 landing 的 Resend key ────────────
# 见 ECS02 /opt/play-reserve-api/.env(同一 Resend 账号)
RESEND_API_KEY=
RESEND_FROM=Stellatrix Labs <noreply@stellatrix.icu>

# ── 反馈 NSFW 预审(T8 — FB-04)──────────────────────────────────
# 可选。缺则所有反馈走人工 review 队列,不拦截。
# OpenAI moderation API 免费、无 token 计费
OPENAI_MODERATION_API_KEY=

# ── 首位管理员注册令牌(REG/setup-token 流程)───────────────────────
# openssl rand -hex 32
# 设完一次 admin 注册后立刻删除这个值再 docker compose up -d 重启
RPG_SETUP_TOKEN=

# ── admin 默认 LLM 配置(普通用户走自己的 BYOK,这里只是 admin 兜底)─
# 测试期可留空(admin 自己注册后从 UI 配)
ANTHROPIC_API_KEY=
EMBED_BASE_URL=
EMBED_MODEL=text-embedding-004
EMBED_API_KEY=
