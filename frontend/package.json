{
  "name": "rpg-roleplay-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:types": "cd ../rust && cargo test -p rpg-schemas --features ts-rs && cargo test -p rpg-state --features ts-rs && cargo test -p rpg-llm --features ts-rs && cargo test -p rpg-routes --features ts-rs"
  },
  "dependencies": {
    "@cloudscape-design/components": "^3.0.1304",
    "@cloudscape-design/global-styles": "^1.0.59",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^7.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.3",
    "web-vitals": "^4.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.19",
    "vitest": "^4.1.7"
  }
}
